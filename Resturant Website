  <div class="hero-btns">
    <button class="btn-gold" onclick="document.getElementById('menu').scrollIntoView({behavior:'smooth'})">Explore Menu</button>
    <button class="btn-outline" onclick="document.getElementById('reservation').scrollIntoView({behavior:'smooth'})">Book a Table</button>
  </div>
</section>

<section id="menu">
