<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>La Maison – Fine Dining</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Lato:wght@300;400;700&display=swap" rel="stylesheet"/>
  <style>
    :root {
      --bg: #0d0b08;
      --surface: #16130e;
      --card: #1e1a13;
      --gold: #c9a84c;
      --gold-light: #e8c97a;
      --cream: #f5ede0;
      --muted: #8a7d6b;
      --red: #c0392b;
      --green: #27ae60;
      --radius: 12px;
    }
    * { margin:0; padding:0; box-sizing:border-box; }
    body { background:var(--bg); color:var(--cream); font-family:'Lato',sans-serif; min-height:100vh; }

    nav {
      position:fixed; top:0; width:100%; z-index:100;
      background:rgba(13,11,8,0.92); backdrop-filter:blur(12px);
      border-bottom:1px solid rgba(201,168,76,0.2);
      display:flex; align-items:center; justify-content:space-between;
      padding:0 6vw; height:70px;
    }
    .logo { font-family:'Playfair Display',serif; font-size:1.6rem; color:var(--gold); letter-spacing:2px; }
    .nav-links { display:flex; gap:2rem; list-style:none; }
    .nav-links a { color:var(--muted); text-decoration:none; font-size:.9rem; letter-spacing:1px; text-transform:uppercase; transition:color .25s; }
    .nav-links a:hover { color:var(--gold); }
    .nav-cart {
      background:var(--gold); color:var(--bg); border:none; border-radius:50px;
      padding:.5rem 1.2rem; font-weight:700; cursor:pointer; font-size:.85rem;
      display:flex; align-items:center; gap:.4rem; transition:background .25s;
    }
    .nav-cart:hover { background:var(--gold-light); }
    #cart-count {
      background:var(--red); color:#fff; border-radius:50%;
      width:20px; height:20px; display:flex; align-items:center; justify-content:center;
      font-size:.7rem; font-weight:900;
    }

    #hero {
      min-height:100vh; display:flex; flex-direction:column;
      align-items:center; justify-content:center; text-align:center;
      padding:0 6vw;
      background: radial-gradient(ellipse at 50% 60%, rgba(201,168,76,0.08) 0%, transparent 70%),
                  url('https://images.unsplash.com/photo-1517248135467-4c7edcad34c4?w=1600&q=80') center/cover no-repeat;
      position:relative;
    }
    #hero::before {
      content:''; position:absolute; inset:0;
      background:linear-gradient(to bottom, rgba(13,11,8,.7) 0%, rgba(13,11,8,.85) 100%);
    }
    #hero > * { position:relative; }
    .hero-tag { color:var(--gold); letter-spacing:4px; text-transform:uppercase; font-size:.8rem; margin-bottom:1rem; }
    #hero h1 { font-family:'Playfair Display',serif; font-size:clamp(2.8rem,6vw,5rem); line-height:1.1; margin-bottom:1.2rem; }
    #hero h1 em { color:var(--gold); font-style:italic; }
    #hero p { color:var(--muted); max-width:520px; line-height:1.7; margin-bottom:2.2rem; font-size:1.05rem; }
    .hero-btns { display:flex; gap:1rem; flex-wrap:wrap; justify-content:center; }
    .btn-gold {
      background:var(--gold); color:var(--bg); padding:.75rem 2rem;
      border:none; border-radius:50px; font-weight:700; font-size:.95rem;
      cursor:pointer; transition:background .25s, transform .2s;
    }
    .btn-gold:hover { background:var(--gold-light); transform:translateY(-2px); }
    .btn-outline {
      background:transparent; color:var(--gold); padding:.75rem 2rem;
      border:1.5px solid var(--gold); border-radius:50px; font-weight:700; font-size:.95rem;
      cursor:pointer; transition:all .25s;
    }
    .btn-outline:hover { background:rgba(201,168,76,0.1); }

    section { padding:6rem 6vw; }
    .section-tag { color:var(--gold); letter-spacing:4px; text-transform:uppercase; font-size:.75rem; margin-bottom:.6rem; }
    .section-title { font-family:'Playfair Display',serif; font-size:clamp(1.8rem,4vw,2.8rem); margin-bottom:.5rem; }
    .section-sub { color:var(--muted); margin-bottom:3rem; max-width:560px; line-height:1.7; }
    .divider { width:60px; height:2px; background:var(--gold); margin:1.2rem 0 2rem; }

    .filter-bar { display:flex; gap:.6rem; flex-wrap:wrap; margin-bottom:2.5rem; }
    .filter-btn {
      background:var(--card); color:var(--muted); border:1px solid rgba(201,168,76,0.15);
      padding:.45rem 1.1rem; border-radius:50px; cursor:pointer; font-size:.85rem;
      transition:all .2s; font-family:'Lato',sans-serif;
    }
    .filter-btn.active, .filter-btn:hover { background:var(--gold); color:var(--bg); border-color:var(--gold); font-weight:700; }

    .menu-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(280px,1fr)); gap:1.5rem; }
    .menu-card {
      background:var(--card); border-radius:var(--radius);
      border:1px solid rgba(201,168,76,0.1);
      overflow:hidden; transition:transform .3s, box-shadow .3s;
      position:relative;
    }
    .menu-card:hover { transform:translateY(-6px); box-shadow:0 16px 40px rgba(0,0,0,.5); }
    .menu-card img { width:100%; height:190px; object-fit:cover; display:block; }
    .badge {
      position:absolute; top:12px; left:12px;
      background:var(--gold); color:var(--bg);
      padding:.2rem .7rem; border-radius:50px; font-size:.7rem; font-weight:700;
    }
    .badge.spicy { background:#c0392b; color:#fff; }
    .badge.veg { background:var(--green); color:#fff; }
    .badge.new { background:#8e44ad; color:#fff; }
    .badge.popular { background:#e67e22; color:#fff; }
    .card-body { padding:1.2rem; }
    .card-body h3 { font-family:'Playfair Display',serif; font-size:1.1rem; margin-bottom:.3rem; }
    .card-body p { color:var(--muted); font-size:.83rem; line-height:1.6; margin-bottom:.9rem; }
    .card-footer { display:flex; align-items:center; justify-content:space-between; }
    .price { color:var(--gold); font-weight:700; font-size:1.1rem; }
    .add-btn {
      background:var(--gold); color:var(--bg); border:none;
      width:34px; height:34px; border-radius:50%; font-size:1.3rem;
      cursor:pointer; display:flex; align-items:center; justify-content:center;
      transition:background .2s, transform .2s;
    }
    .add-btn:hover { background:var(--gold-light); transform:scale(1.1); }

    #specials {
      background:linear-gradient(135deg, #1e1a13 0%, #2a2218 100%);
      border-top:1px solid rgba(201,168,76,0.15);
      border-bottom:1px solid rgba(201,168,76,0.15);
    }
    .specials-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(240px,1fr)); gap:1.2rem; }
    .special-card {
      background:rgba(201,168,76,0.05); border:1px solid rgba(201,168,76,0.2);
      border-radius:var(--radius); padding:1.4rem; text-align:center;
    }
    .special-icon { font-size:2.2rem; margin-bottom:.7rem; }
    .special-card h4 { font-family:'Playfair Display',serif; font-size:1rem; margin-bottom:.4rem; color:var(--gold); }
    .special-card p { color:var(--muted); font-size:.82rem; line-height:1.6; }

    #reservation { background:var(--surface); }
    .res-grid { display:grid; grid-template-columns:1fr 1fr; gap:3rem; align-items:start; }
    .res-info p { color:var(--muted); line-height:1.8; margin-bottom:1.5rem; }
    .info-row { display:flex; gap:.8rem; align-items:flex-start; margin-bottom:1rem; }
    .info-icon { font-size:1.3rem; }
    .info-text strong { display:block; color:var(--cream); margin-bottom:.1rem; font-size:.9rem; }
    .info-text span { color:var(--muted); font-size:.82rem; }
    .res-form { display:flex; flex-direction:column; gap:1rem; }
    .form-row { display:grid; grid-template-columns:1fr 1fr; gap:1rem; }
    .form-group { display:flex; flex-direction:column; gap:.4rem; }
    .form-group label { font-size:.8rem; color:var(--muted); text-transform:uppercase; letter-spacing:1px; }
    .form-group input, .form-group select, .form-group textarea {
      background:var(--card); border:1px solid rgba(201,168,76,0.2);
      color:var(--cream); border-radius:8px; padding:.7rem 1rem;
      font-family:'Lato',sans-serif; font-size:.9rem; outline:none;
      transition:border-color .2s;
    }
    .form-group input:focus, .form-group select:focus, .form-group textarea:focus { border-color:var(--gold); }
    .form-group select option { background:var(--card); }
    .form-group textarea { resize:vertical; min-height:90px; }
    .btn-reserve {
      background:var(--gold); color:var(--bg); border:none; border-radius:50px;
      padding:.85rem 2rem; font-weight:700; font-size:1rem;
      cursor:pointer; transition:background .25s; font-family:'Lato',sans-serif;
    }
    .btn-reserve:hover { background:var(--gold-light); }

    .modal-overlay {
      display:none; position:fixed; inset:0; background:rgba(0,0,0,.75);
      z-index:200; align-items:center; justify-content:center;
    }
    .modal-overlay.open { display:flex; }
    .modal {
      background:var(--card); border-radius:16px; width:min(500px,95vw);
      max-height:80vh; overflow-y:auto; border:1px solid rgba(201,168,76,0.2);
    }
    .modal-header {
      padding:1.4rem 1.6rem; border-bottom:1px solid rgba(201,168,76,0.1);
      display:flex; align-items:center; justify-content:space-between;
      position:sticky; top:0; background:var(--card);
    }
    .modal-header h2 { font-family:'Playfair Display',serif; font-size:1.3rem; }
    .close-btn { background:none; border:none; color:var(--muted); font-size:1.5rem; cursor:pointer; }
    .close-btn:hover { color:var(--cream); }
    .cart-items { padding:1.2rem 1.6rem; min-height:80px; }
    .cart-item {
      display:flex; align-items:center; gap:1rem;
      padding:.7rem 0; border-bottom:1px solid rgba(201,168,76,0.07);
    }
    .cart-item-img { width:54px; height:54px; border-radius:8px; object-fit:cover; }
    .cart-item-info { flex:1; }
    .cart-item-info strong { display:block; font-size:.9rem; margin-bottom:.1rem; }
    .cart-item-info span { color:var(--gold); font-size:.85rem; font-weight:700; }
    .qty-controls { display:flex; align-items:center; gap:.5rem; }
    .qty-btn {
      background:rgba(201,168,76,0.15); color:var(--gold); border:none;
      width:26px; height:26px; border-radius:50%; cursor:pointer; font-size:1rem;
      display:flex; align-items:center; justify-content:center;
    }
    .qty-btn:hover { background:var(--gold); color:var(--bg); }
    .qty-num { font-weight:700; min-width:18px; text-align:center; }
    .remove-btn { background:none; border:none; color:var(--red); cursor:pointer; font-size:1.1rem; }
    .cart-footer { padding:1.2rem 1.6rem; border-top:1px solid rgba(201,168,76,0.1); }
    .cart-total { display:flex; justify-content:space-between; margin-bottom:1rem; font-size:1.05rem; }
    .cart-total span:last-child { color:var(--gold); font-weight:700; font-size:1.2rem; }
    .empty-cart { text-align:center; color:var(--muted); padding:2rem 0; }

    footer {
      background:var(--surface); border-top:1px solid rgba(201,168,76,0.15);
      padding:3rem 6vw; text-align:center;
    }
    footer .logo { display:block; margin-bottom:.5rem; }
    footer p { color:var(--muted); font-size:.85rem; margin-top:.5rem; }

    #toast {
      position:fixed; bottom:2rem; right:2rem; background:var(--green);
      color:#fff; padding:.75rem 1.4rem; border-radius:50px;
      font-size:.9rem; font-weight:700; opacity:0; transform:translateY(10px);
      transition:all .3s; pointer-events:none; z-index:300;
    }
    #toast.show { opacity:1; transform:translateY(0); }

    @media(max-width:768px) {
      .res-grid { grid-template-columns:1fr; }
      .form-row { grid-template-columns:1fr; }
      nav { padding:0 4vw; }
      .nav-links { display:none; }
    }
  </style>
</head>
<body>

<nav>
  <div class="logo">La Maison</div>
  <ul class="nav-links">
    <li><a href="#menu">Menu</a></li>
    <li><a href="#specials">Specials</a></li>
    <li><a href="#reservation">Reserve</a></li>
  </ul>
  <button class="nav-cart" onclick="openCart()">
    🛒 Cart <span id="cart-count">0</span>
  </button>
</nav>

<section id="hero">
