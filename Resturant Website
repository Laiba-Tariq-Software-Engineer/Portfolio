  <div class="divider"></div>
  <div class="specials-grid">
    <div class="special-card"><div class="special-icon">👨‍🍳</div><h4>Chef's Special</h4><p>A seasonal creation from our executive chef — changes every week with the freshest local produce.</p></div>
    <div class="special-card"><div class="special-icon">🌿</div><h4>Farm to Table</h4><p>Every vegetable and herb is sourced within 50 km. Taste the difference freshness makes.</p></div>
    <div class="special-card"><div class="special-icon">🎉</div><h4>Happy Hour</h4><p>Mon–Fri, 4–7 PM: 30% off all cocktails and tapas. Perfect for after-work unwinding.</p></div>
    <div class="special-card"><div class="special-icon">🚚</div><h4>Free Delivery</h4><p>Order above PKR 2,000 and enjoy free delivery anywhere within 10 km of our restaurant.</p></div>
  </div>
</section>

<section id="reservation">
  <div class="section-tag">✦ Reserve a Table</div>
  <h2 class="section-title">Make a Reservation</h2>
  <div class="divider"></div>
  <div class="res-grid">
    <div class="res-info">
      <p>Join us for an unforgettable dining experience. Book your table in advance to guarantee the perfect spot.</p>
      <div class="info-row"><div class="info-icon">📍</div><div class="info-text"><strong>Address</strong><span>12 Culinary Lane, F-7 Markaz, Islamabad</span></div></div>
      <div class="info-row"><div class="info-icon">📞</div><div class="info-text"><strong>Phone</strong><span>+92 51 1234 5678</span></div></div>
      <div class="info-row"><div class="info-icon">🕐</div><div class="info-text"><strong>Opening Hours</strong><span>Mon–Sun: 12:00 PM – 11:30 PM</span></div></div>
      <div class="info-row"><div class="info-icon">✉️</div><div class="info-text"><strong>Email</strong><span>reservations@lamaison.pk</span></div></div>
    </div>
    <div>
      <div class="res-form">
        <div class="form-row">
          <div class="form-group"><label>Full Name</label><input type="text" placeholder="Ahmed Khan"/></div>
          <div class="form-group"><label>Phone</label><input type="tel" placeholder="+92 300 0000000"/></div>
        </div>
        <div class="form-row">
          <div class="form-group"><label>Date</label><input type="date"/></div>
          <div class="form-group"><label>Time</label><input type="time"/></div>
        </div>
        <div class="form-row">
          <div class="form-group"><label>Guests</label>
            <select><option>1 Person</option><option>2 People</option><option>3–4 People</option><option>5–6 People</option><option>7+ People</option></select>
          </div>
          <div class="form-group"><label>Occasion</label>
            <select><option>Casual Dining</option><option>Birthday</option><option>Anniversary</option><option>Business Lunch</option><option>Date Night</option></select>
          </div>
        </div>
        <div class="form-group"><label>Special Requests</label><textarea placeholder="Allergies, seating preferences, or anything else…"></textarea></div>
        <button class="btn-reserve" onclick="showToast('Reservation request sent! We will confirm shortly.')">Confirm Reservation</button>
      </div>
    </div>
  </div>
</section>

<footer>
  <span class="logo">La Maison</span>
  <p>© 2024 La Maison Fine Dining · Islamabad, Pakistan</p>
  <p style="margin-top:.4rem;">🍽️ Taste the art. Live the experience.</p>
</footer>

<div class="modal-overlay" id="cartModal">
  <div class="modal">
    <div class="modal-header">
      <h2>🛒 Your Order</h2>
      <button class="close-btn" onclick="closeCart()">✕</button>
    </div>
    <div class="cart-items" id="cartItems">
      <div class="empty-cart">Your cart is empty.<br/>Add something delicious!</div>
    </div>
    <div class="cart-footer" id="cartFooter" style="display:none;">
      <div class="cart-total"><span>Total:</span><span id="cartTotal">PKR 0</span></div>
      <button class="btn-reserve" style="width:100%;" onclick="showToast('Order placed! Estimated time: 30–45 min 🎉'); clearCart();">Place Order</button>
    </div>
  </div>
</div>

<div id="toast"></div>

